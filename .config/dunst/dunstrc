[global]
    width = 400
    offset = (5, 5)

    progress_bar_min_width = 380
    progress_bar_max_width = 380
    progress_bar_corner_radius = 0
    highlight = "#718096"

    padding = 10
    horizontal_padding = 10
    frame_width = 2
    gap_size = 3
    font = "Monospace 14"

    background = "#000000"
    foreground = "#e0e0e0"

[urgency_low]
    background = "#000000"
    frame_color = "#718096"
    format = "<b><span foreground='#718096'>%s</span></b>\n%b"

[urgency_normal]
    background = "#000000"
    frame_color = "#718096"
    format = "<b><span foreground='#718096'>%s</span></b>\n%b"

[urgency_critical]
    background = "#000000"
    frame_color = "#eb6f92"
    format = "<b><span foreground='#eb6f92'>%s</span></b>\n%b"
